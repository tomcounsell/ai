{
  "$schema": "Project configuration for multi-instance Valor deployment",

  "personas": {
    "developer": {
      "name": "Valor",
      "soul": "~/Desktop/Valor/personas/developer.md",
      "permissions": ["read", "write", "execute"],
      "description": "Full developer persona — reads code, writes code, runs tests, creates PRs"
    },
    "project-manager": {
      "name": "Valor",
      "soul": "~/Desktop/Valor/personas/project-manager.md",
      "permissions": ["read"],
      "description": "PM persona — reads code, manages GitHub issues/PRs, drafts communications. No code writes."
    },
    "teammate": {
      "name": "Valor",
      "soul": "~/Desktop/Valor/personas/teammate.md",
      "permissions": ["read"],
      "description": "Casual teammate persona — conversational Q&A, light and helpful. Read-only, no code writes."
    }
  },

  "projects": {
    "my-project": {
      "name": "My Project",
      "description": "Description of the project",
      "working_directory": "~/src/my-project",
      "machine": "Machine Name",
      "auto_merge": false,
      "telegram": {
        "groups": {
          "Dev: My Project": {"chat_id": -1234567890, "persona": "developer"},
          "PM: My Project": {"chat_id": -9876543210, "persona": "project-manager"}
        },
        "respond_to_unaddressed": true,
        "respond_to_dms": true,
        "dm_persona": "teammate"
      },
      "github": {
        "org": "your-org",
        "repo": "your-repo"
      },
      "linear": {
        "team": "TEAM"
      },
      "context": {
        "tech_stack": ["Python", "Framework"],
        "description": "Focus areas for this project"
      }
    }
  },

  "dms": {
    "persona": "teammate",
    "working_directory": "~/src/ai",
    "description": "All DMs use teammate persona. Casual conversation, read-only."
  },

  "defaults": {
    "working_directory": "~/src",
    "telegram": {
      "respond_to_all": true,
      "respond_to_mentions": true,
      "respond_to_dms": false,
      "dm_persona": "teammate",
      "mention_triggers": ["@valor", "valor", "hey valor"]
    },
    "response": {
      "typing_indicator": true,
      "max_response_length": 4000,
      "timeout_seconds": 300
    }
  }
}

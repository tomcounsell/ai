{
  "$schema": "Project configuration for multi-instance Valor deployment",

  "personas": {
    "developer": {
      "name": "Valor",
      "soul": "config/personas/developer.md",
      "permissions": ["read", "write", "execute"],
      "description": "Full developer persona — reads code, writes code, runs tests, creates PRs"
    },
    "project-manager": {
      "name": "Valor",
      "soul": "config/personas/project-manager.md",
      "permissions": ["read"],
      "description": "PM persona — reads code, manages GitHub issues/PRs, drafts communications. No code writes."
    },
    "teammate": {
      "name": "Valor",
      "soul": "config/personas/teammate.md",
      "permissions": ["read"],
      "description": "Casual teammate persona — conversational Q&A, light and helpful. Read-only, no code writes."

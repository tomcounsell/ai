{% autoescape off %}{% load podcast_tags %}<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0"
     xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd"
     xmlns:podcast="https://podcastindex.org/namespace/1.0"
     xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ podcast.title }}</title>
    <link>{{ podcast.website_url }}</link>
    <description>{{ podcast.description }}</description>
    <language>{{ podcast.language }}</language>
    <copyright>{{ podcast.author_name }}</copyright>
    <lastBuildDate>{{ episodes.0.published_at|date:"D, d M Y H:i:s O" }}</lastBuildDate>
    <atom:link href="{{ request.build_absolute_uri }}" rel="self" type="application/rss+xml"/>

    <itunes:author>{{ podcast.author_name }}</itunes:author>
    <itunes:summary>{{ podcast.description }}</itunes:summary>
    {% if podcast.cover_image_url %}<itunes:image href="{{ podcast.cover_image_url }}"/>{% endif %}
    <itunes:explicit>false</itunes:explicit>
    {% for category in podcast.categories %}<itunes:category text="{{ category }}"/>
    {% endfor %}
    <itunes:owner>
      <itunes:name>{{ podcast.author_name }}</itunes:name>
      <itunes:email>{{ podcast.author_email }}</itunes:email>
    </itunes:owner>

    <podcast:locked>yes</podcast:locked>
{% for episode in episodes %}
    <item>
      <title>{{ episode.title }}</title>
      <link>{{ podcast.website_url }}</link>
      <description>{{ episode.description }}</description>
      <pubDate>{{ episode.published_at|date:"D, d M Y H:i:s O" }}</pubDate>
      <guid isPermaLink="false">{{ episode.audio_url }}</guid>
      <enclosure url="{{ episode.audio_url }}" length="{{ episode.audio_file_size_bytes|default_zero }}" type="audio/mpeg"/>

      <itunes:duration>{{ episode.audio_duration_seconds|duration_hhmmss }}</itunes:duration>
      <itunes:episode>{{ episode.episode_number }}</itunes:episode>
      <itunes:explicit>{% if episode.is_explicit %}true{% else %}false{% endif %}</itunes:explicit>
      {% if episode.effective_cover_image_url %}<itunes:image href="{{ episode.effective_cover_image_url }}"/>{% endif %}
      <itunes:summary>{{ episode.description }}</itunes:summary>
    </item>
{% endfor %}
  </channel>
</rss>
{% endautoescape %}
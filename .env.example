# Valor AI System Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# ACTIVE PROJECTS (Which Telegram groups this machine monitors)
# =============================================================================

# Comma-separated list of project keys from ~/Desktop/Valor/projects.json
# Each project defines which Telegram groups it listens to
# When a message comes in, Valor identifies the project and injects its context
#
# Examples:
#   ACTIVE_PROJECTS=valor                           # Just Valor project
#   ACTIVE_PROJECTS=valor,popoto                    # Multiple projects
#   ACTIVE_PROJECTS=valor,popoto,django-project-template  # All projects
ACTIVE_PROJECTS=valor

# =============================================================================
# Agent Backend
# =============================================================================

# SDK billing mode: subscription (default) vs API credits
# When false/unset, the SDK omits the API key so Claude CLI falls back to
# OAuth subscription auth from `claude login` (uses Max plan, no per-token cost).
# Set to "true" ONLY if subscription auth stops working and you need API billing.
USE_API_BILLING=false

# =============================================================================
# API Keys
# =============================================================================

# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-****

# OpenAI API Key (Optional - for image generation/analysis)
OPENAI_API_KEY=sk-****

# Perplexity AI API (Optional - for web search)
PERPLEXITY_API_KEY=pplx-****

# =============================================================================
# Telegram Configuration
# =============================================================================

# Telegram Developer API (get from my.telegram.org)
TELEGRAM_API_ID=12345****
TELEGRAM_API_HASH=abcd1234****

# Telegram Account (for user account auth)
TELEGRAM_PHONE=+1234567****
TELEGRAM_PASSWORD=your_password_****

# Session name (unique per instance if sharing Telegram account)
TELEGRAM_SESSION_NAME=valor_bridge

# DM Whitelist: Only respond to DMs from these users (comma-separated)
# Leave empty to respond to all DMs, or specify names/usernames
# Example: TELEGRAM_DM_WHITELIST=Tom,alice,bob
TELEGRAM_DM_WHITELIST=Tom

# =============================================================================
# Service Integrations (Optional - for MCP servers)
# =============================================================================
# These API keys enable service integrations via MCP servers.

# Notion API Key (for documentation skill)
NOTION_API_KEY=ntn_****

# Sentry (for error monitoring skill)
SENTRY_API_KEY=****
SENTRY_ORG_SLUG=your-org

# Sentry SDK (for error tracking in the bridge process)
SENTRY_DSN=https://6c263d512a49826d9f4d63578d86d3d1@o4508986235682816.ingest.us.sentry.io/4511091961888768
SENTRY_ENVIRONMENT=production

# GitHub (for repository skill)
GITHUB_TOKEN=ghp_****

# Linear (for project management skill)
LINEAR_API_KEY=lin_api_****

# Stripe (for payment skill)
STRIPE_API_KEY=sk_****

# Render (for deployment skill)
RENDER_API_KEY=rnd_****

# =============================================================================
# Multi-Instance Deployment
# =============================================================================
#
# Valor runs on every machine as a service. Each machine monitors specific
# Telegram groups based on ACTIVE_PROJECTS.
#
# When a message arrives:
# 1. Bridge checks if the group matches any active project
# 2. If yes, injects that project's context and responds
# 3. If no, ignores the message
#
# Example configurations:
#
# Machine A (single project):
#   ACTIVE_PROJECTS=valor
#   # Monitors "Dev: Valor" group only
#
# Machine B (multiple projects):
#   ACTIVE_PROJECTS=popoto,django-project-template
#   # Monitors "Dev: Popoto" and "Dev: Django Template" groups
#
# Machine C (all projects):
#   ACTIVE_PROJECTS=valor,popoto,django-project-template
#   # Monitors all configured groups
#

# Reflections bug issues: set to false to disable automatic GitHub issue creation for bugs
REFLECTIONS_AUTO_FIX_ENABLED=true

# =============================================================================
# Infrastructure
# =============================================================================

# Redis connection URL (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# OpenRouter API Key (Optional - for model routing)
OPENROUTER_API_KEY=sk-or-****

# =============================================================================
# Local Models (Ollama)
# =============================================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama vision model for local image analysis (default: llama3.2-vision:11b)
OLLAMA_VISION_MODEL=llama3.2-vision:11b

# =============================================================================
# Feature Flags
# =============================================================================

# Enable semantic routing for message classification (default: false)
SEMANTIC_ROUTING=false

# Comma-separated Telegram group IDs for link collection
TELEGRAM_LINK_COLLECTORS=

# =============================================================================
# Session Management
# =============================================================================

# Task list ID for Claude Code session isolation (auto-set by bridge)
CLAUDE_CODE_TASK_LIST_ID=

# =============================================================================
# Google Workspace
# =============================================================================

# Directory for Google OAuth credentials (default: ~/Desktop/Valor/)
# This directory is iCloud-synced across machines
GOOGLE_CREDENTIALS_DIR=~/Desktop/Valor

# =============================================================================
# Private Configuration (iCloud-synced)
# =============================================================================

# Path to projects.json (default: ~/Desktop/Valor/projects.json)
# Contains chat IDs, machine names, and project configs — not committed to repo
PROJECTS_CONFIG_PATH=~/Desktop/Valor/projects.json

# Valor AI System Configuration
# Documents the contents of <vault>/.env. The vault directory is configurable
# per machine via VALOR_VAULT_DIR (see below); the established default is
# ~/Desktop/Valor/. Do NOT copy this file to .env — the repo .env is a symlink
# to the vault. To add a new secret: add it to <vault>/.env, then document it
# here.

# =============================================================================
# VAULT LOCATION
# =============================================================================
# Directory where Valor's secrets vault lives. The repo .env is symlinked to
# <vault>/.env; projects.json, persona overlays, and Google credentials all
# live under this directory by default.
#
# Resolution cascade: VALOR_VAULT_DIR > ~/Desktop/Valor/.env > error.
#
# If you set this in .env, the value is informational/redundant for processes
# that already loaded the .env (the symlink encodes the location). It matters
# for processes that haven't loaded .env yet — notably launchd-managed services
# (worker, watchdog, reflections), which is why install_*.sh scripts inject
# this var directly into their plists' EnvironmentVariables dict.
#
# Pick a different location via /setup, then re-run install_worker.sh etc. to
# regenerate the plists.
# VALOR_VAULT_DIR=~/Desktop/Valor

# =============================================================================
# SERVICE LABEL PREFIX (launchd)
# =============================================================================
# Prefix used for all macOS launchd Label fields and on-disk plist filenames
# in ~/Library/LaunchAgents/. Forks/downstream installs should override this
# (e.g. com.example) so multiple installs can coexist. The canonical Valor
# install uses com.valor.
#
# NOTE: This is an INSTALL-TIME setting. launchd binds to the label baked at
# install time, so changing this in .env on a running machine has no effect
# until you uninstall and reinstall the services. valor-service.sh detects
# drift and warns loudly.
SERVICE_LABEL_PREFIX=com.valor

# =============================================================================
# ACTIVE PROJECTS (Which Telegram groups this machine monitors)
# =============================================================================

# Comma-separated list of project keys from <vault>/projects.json (default vault: ~/Desktop/Valor/)
# Each project defines which Telegram groups it listens to
# When a message comes in, Valor identifies the project and injects its context
#
# Examples:
#   ACTIVE_PROJECTS=valor                           # Just Valor project
#   ACTIVE_PROJECTS=valor,popoto                    # Multiple projects
#   ACTIVE_PROJECTS=valor,popoto,django-project-template  # All projects
ACTIVE_PROJECTS=valor

# Project namespace prefix used by recovery reflections (circuit_health_gate,
# session_recovery_drip) and by worker queue-pause/hibernation gating. Must match
# the project key used by AgentSession writers (tools.agent_session_scheduler.DEFAULT_PROJECT_KEY)
# and the active projects.json key for this codebase. Injected into worker/bridge
# launchd plists by the install scripts. See issue #1171.
VALOR_PROJECT_KEY=valor

# =============================================================================
# Agent Backend
# =============================================================================

# SDK billing mode: subscription (default) vs API credits
# When false/unset, the SDK omits the API key so Claude CLI falls back to
# OAuth subscription auth from `claude login` (uses Max plan, no per-token cost).
# Set to "true" ONLY if subscription auth stops working and you need API billing.
USE_API_BILLING=false

# Maximum number of sessions that can execute simultaneously across all chat_ids.
# Prevents resource exhaustion when multiple chat groups have pending sessions.
# Minimum value is 1 (enforced by the worker). Default: 8
# MAX_CONCURRENT_SESSIONS=8

# =============================================================================
# API Keys
# =============================================================================

# Anthropic API Key (Required)
ANTHROPIC_API_KEY=sk-ant-****

# Long-lived (~1-year) Claude subscription OAuth token for granite PTY auth prevention (mint via: claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-****

# OpenAI API Key (Optional - for image generation/analysis)
OPENAI_API_KEY=sk-****

# Cross-vendor review judge (issue #1626) — behavior toggles, not secrets.
# Default OFF — enable on the review machine only. Provisional/tunable defaults.
SDLC_REVIEW_CROSS_VENDOR=0
# Provisional model id — override if gpt-4o is unavailable on your account.
SDLC_REVIEW_CROSS_VENDOR_MODEL=gpt-4o
# Provisional token cap — tune based on cost tolerance (tokens, not lines).
SDLC_REVIEW_CROSS_VENDOR_MAX_DIFF_TOKENS=50000
# Fail-closed: set to 1 to require the cross-vendor judge (CHANGES REQUESTED if it skips).
SDLC_REVIEW_CROSS_VENDOR_REQUIRED=0

# Perplexity AI API (Optional - for web search)
PERPLEXITY_API_KEY=pplx-****

# =============================================================================
# Telegram Configuration
# =============================================================================

# Telegram Developer API credentials (get from my.telegram.org under API Development Tools)
TELEGRAM_API_ID=12345****
# Telegram Developer API hash — paired with TELEGRAM_API_ID; both required for Telethon auth
TELEGRAM_API_HASH=abcd1234****

# Telegram Account (for user account auth)
TELEGRAM_PHONE=+1234567****
# Telegram account 2FA password (optional; only required if Two-Step Verification is enabled on the account)
TELEGRAM_PASSWORD=your_password_****

# Session name (unique per instance if sharing Telegram account)
TELEGRAM_SESSION_NAME=valor_bridge

# =============================================================================
# Service Integrations (Optional - for MCP servers)
# =============================================================================
# These API keys enable service integrations via MCP servers.

# Notion API Key (for documentation skill)
NOTION_API_KEY=ntn_****

# Sentry (for error monitoring skill)
SENTRY_API_KEY=****
# Sentry organization slug — found in your Sentry org URL (e.g. app.sentry.io/organizations/<slug>/)
SENTRY_ORG_SLUG=your-org

# Sentry SDK (for error tracking in the bridge process)
# NOTE: Historical commits in this repo still contain an older DSN that has
# since been rotated/revoked in Sentry (test events return HTTP 403). Use your
# own DSN here — never commit a real one.
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project
# Sentry environment tag attached to all events (e.g. production, staging, dev)
SENTRY_ENVIRONMENT=production

# GitHub (for repository skill)
# Use GITHUB_PAT — the update orchestrator loads it into gh's keyring automatically.
# GITHUB_TOKEN is intentionally NOT set here (when present it overrides gh's keyring).
GITHUB_PAT=ghp_****

# Optional. GitHub PAT for a dedicated SDLC bot account (e.g. yudame-sdlc-bot) used
# by /do-pr-review in pipeline context (CLAUDE_AGENT_REVIEW=1). Standard machines
# leave this blank — pipeline reviews then post under the operator's gh credential.
# Only the dedicated bot machine sets a value, in which case reviews post under the
# bot identity with the <!-- SDLC-AGENT-REVIEW v1 --> marker. Must have `repo` scope
# on reviewed repos. See docs/features/do-pr-review-bot-identity.md.
SDLC_AGENT_GH_TOKEN=

# Linear (for project management skill)
LINEAR_API_KEY=lin_api_****

# Stripe (for payment skill)
STRIPE_API_KEY=sk_****

# Render (for deployment skill)
RENDER_API_KEY=rnd_****

# =============================================================================
# Multi-Instance Deployment
# =============================================================================
#
# Valor runs on every machine as a service. Each machine monitors specific
# Telegram groups based on ACTIVE_PROJECTS.
#
# When a message arrives:
# 1. Bridge checks if the group matches any active project
# 2. If yes, injects that project's context and responds
# 3. If no, ignores the message
#
# Example configurations:
#
# Machine A (single project):
#   ACTIVE_PROJECTS=valor
#   # Monitors "Dev: Valor" group only
#
# Machine B (multiple projects):
#   ACTIVE_PROJECTS=popoto,django-project-template
#   # Monitors "Dev: Popoto" and "Dev: Django Template" groups
#
# Machine C (all projects):
#   ACTIVE_PROJECTS=valor,popoto,django-project-template
#   # Monitors all configured groups
#

# Reflections bug issues: set to false to disable automatic GitHub issue creation for bugs
REFLECTIONS_AUTO_FIX_ENABLED=true

# =============================================================================
# Infrastructure
# =============================================================================

# Redis connection URL (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# OpenRouter API Key (Optional - for model routing)
OPENROUTER_API_KEY=sk-or-****

# =============================================================================
# Local Models (Ollama)
# =============================================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama vision model for local image analysis (default: gemma4:e2b — same
# multimodal model as OLLAMA_LOCAL_MODEL so one pull covers text + vision).
OLLAMA_VISION_MODEL=gemma4:e2b

# =============================================================================
# Session Model Routing
# =============================================================================

# Codebase default for Claude sessions (PM, Teammate, Dev) when AgentSession.model
# is not explicitly set. Precedence cascade (closest to LLM call wins):
#   1. AgentSession.model (per-session, via `valor-session create --model <name>`)
#   2. MODELS__SESSION_DEFAULT_MODEL (this var — machine-local override)
#   3. codebase default ("opus")
# Short aliases: opus, sonnet, haiku. Full names also accepted.
# MODELS__SESSION_DEFAULT_MODEL=opus

# =============================================================================
# Email Bridge (IMAP/SMTP)
# =============================================================================

# Gmail App Password setup: Google Account → Security → 2-Step Verification → App Passwords
# Create an App Password for "Mail" and use it here (not your regular password).
# Gmail IMAP: imap.gmail.com:993 (SSL), Gmail SMTP: smtp.gmail.com:587 (STARTTLS)

# IMAP server hostname for inbound email polling (default: imap.gmail.com)
IMAP_HOST=imap.gmail.com
# IMAP server port — 993 for SSL, 143 for STARTTLS
IMAP_PORT=993
# IMAP login username (your Gmail address)
IMAP_USER=valor@yuda.me
# IMAP login password — use a Gmail App Password, not your account password
IMAP_PASSWORD=your-gmail-app-password-here
# Set to "false" to disable SSL (not recommended)
IMAP_SSL=true
# Seconds between IMAP polls (default: 30)
IMAP_POLL_INTERVAL=30

# SMTP server hostname for outbound email delivery (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP server port — 587 for STARTTLS, 465 for SSL
SMTP_PORT=587
# SMTP login username (your Gmail address)
SMTP_USER=valor@yuda.me
# SMTP login password — use a Gmail App Password, not your account password
SMTP_PASSWORD=your-gmail-app-password-here
# Set to "false" to disable STARTTLS (not recommended)
SMTP_USE_TLS=true

# =============================================================================
# Knowledge Ingestion (markitdown)
# =============================================================================

# LLM model used by markitdown for image description and PPTX image OCR.
# Leave unset to use the subprocess-only path (handles PDF/DOCX/XLSX/HTML/EPUB
# without any LLM). Set to the value of config.models.HAIKU to enable vision
# descriptions for standalone images and image-heavy PowerPoint decks.
# If the Haiku probe fails at first invocation, the converter logs a WARNING
# once and routes image/PPTX conversions through the subprocess path (image
# filename only, no description). No OPENAI fallback — see Risk 3 / C5 of the
# plan for rationale.
# MARKITDOWN_LLM_MODEL=

# =============================================================================
# Feature Flags
# =============================================================================

# Comma-separated Telegram group IDs for link collection
TELEGRAM_LINK_COLLECTORS=

# Read-the-Room pre-send pass (issue #1193). When true, every Path A outbound
# message goes through a Haiku verdict (send|trim|suppress) inspecting the
# recent chat snapshot before the relay write. Default off -- opt in per
# machine after verifying latency on a low-stakes chat. Path B
# (valor-telegram send) deliberately does not pass through RTR yet; see the
# Path B follow-up issue tracked alongside #1193.
READ_THE_ROOM_ENABLED=false

# Drafter redundancy suppression (issue #1205). Deterministic bigram-Jaccard
# guard that suppresses near-verbatim repeated PM status messages. Defaults
# shown; set DRAFTER_REDUNDANCY_SUPPRESSION_ENABLED=false to disable globally.
# Kill switch: DRAFTER_REDUNDANCY_SUPPRESSION_ENABLED=false restores pre-fix behavior.
DRAFTER_REDUNDANCY_SUPPRESSION_ENABLED=true
# Bigram Jaccard threshold (0–1). Drafts with J >= threshold are candidates
# for suppression. Conservative default: 0.65 catches near-verbatim repeats
# while allowing genuine paraphrases through.
DRAFTER_REDUNDANCY_THRESHOLD=0.65
# Number of recent sent drafts to retain per session for comparison.
DRAFTER_RECENT_DRAFTS_N=3
# Time window (seconds) within which prior drafts are eligible for comparison.
# Entries older than this window are skipped. Default: 600 (10 minutes).
DRAFTER_REDUNDANCY_WINDOW_SECONDS=600
# High-confidence cutoff used by the PM completion runner when deciding whether
# to suppress a final-delivery summary that restates a mid-session send (issue
# #1262). The runner calls should_suppress() with threshold=0.55 (LOW band) and
# enforces this HIGH cutoff in the caller; J >= HIGH suppresses without LLM
# cost, 0.55 <= J < HIGH escalates to a Haiku judge. Default: 0.75.
DRAFTER_COMPLETION_REDUNDANCY_THRESHOLD=0.75

# =============================================================================
# Crash Auto-Resume Policy (issue #1539)
# =============================================================================
# Enable ONLY on the one designated auto-resume machine; off elsewhere (propose-only).
# All other machines log proposals but never act. See docs/features/crash-recovery.md.
FEATURES__CRASH_AUTORESUME_ENABLED=
# Per-session cap on automatic resume attempts (default: 3).
FEATURES__CRASH_AUTORESUME_MAX_ATTEMPTS=
# Maximum sessions auto-resumed per reflection run, guards against misfires (default: 5).
FEATURES__CRASH_AUTORESUME_RUN_BUDGET=
# Minimum crash-pattern observations before auto-resume is eligible (default: 3).
FEATURES__CRASH_AUTORESUME_MIN_OCCURRENCES=
# Minimum recovery success ratio for auto-resume eligibility (default: 0.7).
FEATURES__CRASH_AUTORESUME_MIN_SUCCESS_RATIO=

# Gates the stall-recovery actor (issue #1768): when true, the stall-advisory
# reflection kills demonstrably-wedged sessions and re-enqueues via valor-catchup.
# Off by default (dry-run/observe-only); the int thresholds use safe defaults.
FEATURES__STALL_RECOVERY_ENABLED=false

# =============================================================================
# Per-Tool Timeout Sub-Loop (issue #1270)
# =============================================================================
# Detects sessions whose `current_tool_name` is non-null but whose
# `last_tool_use_at` exceeds the tier-specific budget — the tool's PreToolUse
# hook fired but PostToolUse never returned. Defaults are conservative; the
# 30s internal-tier budget matches the dedicated 30s sub-loop cadence.

# Kill switch — set to "1" to short-circuit the entire sub-loop. The main
# 5-minute health loop is unaffected (parity with DISABLE_PROGRESS_KILL).
TOOL_TIMEOUT_TIERS_DISABLED=

# Internal-tier budget (seconds). Applies to lightweight built-in tools
# (ToolSearch, Read, Glob, Grep, Edit, Write, NotebookEdit) that should
# never legitimately exceed 30s.
TOOL_TIMEOUT_INTERNAL_SEC=30

# MCP-tier budget (seconds). Applies to any tool whose name starts with
# `mcp__` (Model Context Protocol servers). 120s accommodates remote-server
# round-trips while still bounding wedges.
TOOL_TIMEOUT_MCP_SEC=120

# Default-tier budget (seconds). Applies to everything else (Bash, Task,
# Skill, WebFetch, ...). 5 minutes matches Fazm's chosen default; users who
# legitimately run longer commands (e.g. `npm install`) can raise this.
TOOL_TIMEOUT_DEFAULT_SEC=300

# =============================================================================
# Google Workspace
# =============================================================================

# Directory for Google OAuth credentials. Default: vault.google_credentials_dir
# (i.e. <vault>/, where <vault> is set via VALOR_VAULT_DIR; established default
# is ~/Desktop/Valor/). Uncomment + set ONLY if you want to override the vault
# default — leaving this commented lets the vault cascade resolve it.
# GOOGLE_CREDENTIALS_DIR=~/Desktop/Valor

# =============================================================================
# Private Configuration (iCloud-synced)
# =============================================================================

# Path to projects.json. Default: vault.projects_path (i.e. <vault>/projects.json,
# where <vault> is set via VALOR_VAULT_DIR; established default is
# ~/Desktop/Valor/projects.json). Uncomment + set ONLY if you want to override the
# vault default — leaving this commented lets the vault cascade resolve it.
# Contains chat IDs, machine names, and project configs — not committed to repo.
# PROJECTS_CONFIG_PATH=~/Desktop/Valor/projects.json

# Anna's Archive API credentials (paid member fast-download access)
# https://annas-archive.org/account — used by the ebook-ingest skill
ANNAS_ARCHIVE_ACCOUNT_ID=
ANNAS_ARCHIVE_SECRET_KEY=

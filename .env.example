# Django Settings
SECRET_KEY=generate_a_secure_key_here
DEPLOYMENT_TYPE=LOCAL  # LOCAL, STAGE, DEMO, PRODUCTION
DEBUG=True

# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Alternative config
# DB_NAME=local_postgres_db_name
# DB_USER=local_postgres_username
# DB_PASSWORD=local_postgres_password
# DB_HOST=localhost
# DB_PORT=5432

# Cache (optional)
# REDIS_URL=redis://127.0.0.1:6379/5

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=project-stage
AWS_REGION=us-east-1
AWS_SNS_NAME=
AWS_MAX_UPLOAD_SIZE=10485760  # 10MB default
AWS_UPLOAD_PREFIX=uploads

# Third-party Integrations
# Loops for transactional email
LOOPS_API_KEY=

# Twilio for SMS messaging
TWILIO_ENABLED=False
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI Integration
OPENAI_API_KEY=
OPENAI_ORG_ID=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01

# xAI Grok API (for automated Grok research)
GROK_API_KEY=

# Supabase Storage (dual-bucket support for public/private files)
# See docs/features/file-storage-service.md for details
SUPABASE_PROJECT_URL=              # e.g. https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # Service role key for uploads (not anon key)
SUPABASE_PUBLIC_BUCKET_NAME=       # Bucket for public files with permanent URLs
SUPABASE_PRIVATE_BUCKET_NAME=      # Bucket for private files with signed URLs (optional)
SUPABASE_USER_ACCESS_TOKEN=        # Token required for private podcast feed access (optional)

# Stripe integration
STRIPE_API_KEY=sk_test_xxx             # Stripe secret key (use test key for development)
STRIPE_WEBHOOK_SECRET=whsec_xxx        # Stripe webhook signing secret (from Stripe dashboard)
STRIPE_PODCAST_PRICE_ID=price_xxx      # Stripe Price ID for private podcast subscription

# Social Auth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# CTO Tools Security Review - Built-in Connectors
# Enable connectors by setting their environment variables

# Snyk SAST Connector (optional)
# SNYK_API_KEY=your_snyk_api_token
# SNYK_ORG_ID=your_organization_id
# SNYK_API_URL=https://api.snyk.io/v1  # Optional, uses default if not set

# AWS Security Hub CSPM Connector (optional)
# Uses standard AWS credentials from the AWS section above
# AWS_SECURITY_HUB_ACCOUNT_ID=your_account_id  # Optional, specific account ID

# Custom connectors: Add Python files to apps/ai/mcp/security/connectors/
# See apps/ai/mcp/security/connectors/README.md for details

# Open Deep Research (LangGraph multi-hop research)
# Uses the LLM key from above (ANTHROPIC_API_KEY preferred, OPENAI_API_KEY, or OPENROUTER_API_KEY)
TAVILY_API_KEY=  # Required for web search (get free key at https://tavily.com/)

# =============================================================================
# Service Integrations (Optional - for MCP servers)
# =============================================================================
# These API keys enable service integrations via MCP servers.

# Notion API Key (for documentation skill)
NOTION_API_KEY=ntn_****

# Sentry (for error monitoring skill)
SENTRY_API_KEY=****
SENTRY_ORG_SLUG=your-org

# Sentry SDK (for error tracking in the bridge process)
# NOTE: Historical commits in this repo still contain an older DSN that has
# since been rotated/revoked in Sentry (test events return HTTP 403). Use your
# own DSN here — never commit a real one.
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project
SENTRY_ENVIRONMENT=production

# GitHub (for repository skill)
GITHUB_TOKEN=ghp_****

# Linear (for project management skill)
LINEAR_API_KEY=lin_api_****

# Stripe (for payment skill)
STRIPE_API_KEY=sk_****

# Render (for deployment skill)
RENDER_API_KEY=rnd_****

# =============================================================================
# Multi-Instance Deployment
# =============================================================================
#
# Valor runs on every machine as a service. Each machine monitors specific
# Telegram groups based on ACTIVE_PROJECTS.
#
# When a message arrives:
# 1. Bridge checks if the group matches any active project
# 2. If yes, injects that project's context and responds
# 3. If no, ignores the message
#
# Example configurations:
#
# Machine A (single project):
#   ACTIVE_PROJECTS=valor
#   # Monitors "Dev: Valor" group only
#
# Machine B (multiple projects):
#   ACTIVE_PROJECTS=popoto,django-project-template
#   # Monitors "Dev: Popoto" and "Dev: Django Template" groups
#
# Machine C (all projects):
#   ACTIVE_PROJECTS=valor,popoto,django-project-template
#   # Monitors all configured groups
#

# Reflections bug issues: set to false to disable automatic GitHub issue creation for bugs
REFLECTIONS_AUTO_FIX_ENABLED=true

# =============================================================================
# Infrastructure
# =============================================================================

# Redis connection URL (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# OpenRouter API Key (Optional - for model routing)
OPENROUTER_API_KEY=sk-or-****

# =============================================================================
# Local Models (Ollama)
# =============================================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama vision model for local image analysis (default: llama3.2-vision:11b)
OLLAMA_VISION_MODEL=llama3.2-vision:11b

# =============================================================================
# Feature Flags
# =============================================================================

# Comma-separated Telegram group IDs for link collection
TELEGRAM_LINK_COLLECTORS=

# =============================================================================
# Session Management
# =============================================================================

# Task list ID for Claude Code session isolation (auto-set by bridge)
CLAUDE_CODE_TASK_LIST_ID=

# =============================================================================
# Google Workspace
# =============================================================================

# Directory for Google OAuth credentials (default: ~/Desktop/Valor/)
# This directory is iCloud-synced across machines
GOOGLE_CREDENTIALS_DIR=~/Desktop/Valor

# =============================================================================
# Private Configuration (iCloud-synced)
# =============================================================================

# Path to projects.json (default: ~/Desktop/Valor/projects.json)
# Contains chat IDs, machine names, and project configs — not committed to repo
PROJECTS_CONFIG_PATH=~/Desktop/Valor/projects.json

# Email Bridge (IMAP/SMTP)
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=valor@yuda.me
IMAP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=valor@yuda.me
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

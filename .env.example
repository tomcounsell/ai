# Django Settings
SECRET_KEY=generate_a_secure_key_here
DEPLOYMENT_TYPE=LOCAL  # LOCAL, STAGE, DEMO, PRODUCTION
DEBUG=True

# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Alternative config
# DB_NAME=local_postgres_db_name
# DB_USER=local_postgres_username
# DB_PASSWORD=local_postgres_password
# DB_HOST=localhost
# DB_PORT=5432

# Cache (optional)
# REDIS_URL=redis://127.0.0.1:6379/5

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=project-stage
AWS_REGION=us-east-1
AWS_SNS_NAME=
AWS_MAX_UPLOAD_SIZE=10485760  # 10MB default
AWS_UPLOAD_PREFIX=uploads

# Third-party Integrations
# Loops for transactional email
LOOPS_API_KEY=

# Twilio for SMS messaging
TWILIO_ENABLED=False
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI Integration
OPENAI_API_KEY=
OPENAI_ORG_ID=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01

# xAI Grok API (for automated Grok research)
GROK_API_KEY=

# Supabase Storage (dual-bucket support for public/private files)
# See docs/features/file-storage-service.md for details
SUPABASE_PROJECT_URL=              # e.g. https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=         # Service role key for uploads (not anon key)
SUPABASE_PUBLIC_BUCKET_NAME=       # Bucket for public files with permanent URLs
SUPABASE_PRIVATE_BUCKET_NAME=      # Bucket for private files with signed URLs (optional)
SUPABASE_USER_ACCESS_TOKEN=        # Token required for private podcast feed access (optional)

# Social Auth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# CTO Tools Security Review - Built-in Connectors
# Enable connectors by setting their environment variables

# Snyk SAST Connector (optional)
# SNYK_API_KEY=your_snyk_api_token
# SNYK_ORG_ID=your_organization_id
# SNYK_API_URL=https://api.snyk.io/v1  # Optional, uses default if not set

# AWS Security Hub CSPM Connector (optional)
# Uses standard AWS credentials from the AWS section above
# AWS_SECURITY_HUB_ACCOUNT_ID=your_account_id  # Optional, specific account ID

# Custom connectors: Add Python files to apps/ai/mcp/security/connectors/
# See apps/ai/mcp/security/connectors/README.md for details

# Open Deep Research (LangGraph multi-hop research)
# Uses the LLM key from above (ANTHROPIC_API_KEY preferred, OPENAI_API_KEY, or OPENROUTER_API_KEY)
TAVILY_API_KEY=  # Required for web search (get free key at https://tavily.com/)
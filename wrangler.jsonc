{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "valorengels-site",
  "compatibility_date": "2026-07-13",
  "main": "src/index.js",
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "routes": [
    {
      "pattern": "valorengels.com",
      "custom_domain": true
    },
    {
      "pattern": "www.valorengels.com",
      "custom_domain": true
    }
  ]
}

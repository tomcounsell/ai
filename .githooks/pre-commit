#!/usr/bin/env bash
# Pre-commit hook: auto-fix lint + scan for leaked secrets
# Install: git config core.hooksPath .githooks
#
# This hook runs two phases:
# 1. Auto-fix: ruff format + ruff check --fix on all staged Python files,
#    then re-stage the fixes. Only genuinely unfixable issues block the commit.
# 2. Secret scan: scan staged files for leaked secrets.
#
# Agents should use --no-verify for intermediate WIP commits and let this
# hook run on final commits to ensure clean code.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Use the venv Python if available (has ruff), fall back to system python3
if [ -f "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/.venv/bin/python"
else
    PYTHON="python3"
fi

# ── Phase 0.5: Session-branch worktree guard (#1288, #1620) ────────────
# Guards commits on `session/{slug}` branches. The guard is self-detecting
# (option (a), allow-when-no-worktree — decided in #1620):
#
#   * If an owning `.worktrees/{slug}/` worktree EXISTS on disk, commits for
#     that slug must happen from inside it — committing from any other working
#     tree (e.g. the main checkout) is BLOCKED, so the worktree's in-progress
#     work cannot be contaminated by a stray commit on the same branch.
#   * If NO such worktree exists, the current checkout is the sole workspace
#     for this slug — there is nothing to contaminate — so the commit is
#     ALLOWED with an informational note on stderr.
#
# Worker-side enforcement (#887) covers AgentSession spawns; this guard covers
# manual `git commit` from the main checkout or any other working tree.
# Detached HEAD is a no-op; non-session branches (main, hotfix, etc.) are
# unaffected.
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$BRANCH" == session/* ]]; then
    SLUG="${BRANCH#session/}"
    TOPLEVEL=$(git rev-parse --show-toplevel)
    if [ -z "$SLUG" ]; then
        echo ""
        echo "COMMIT BLOCKED: branch name '$BRANCH' has an empty slug." >&2
        echo "This is the #1288 guard. A 'session/<slug>' branch must have a non-empty slug." >&2
        echo "Rename the branch to a real session/<name> or move off it before committing." >&2
        echo ""
        exit 1
    fi
    EXPECTED_SUFFIX=".worktrees/${SLUG}"
    if [[ "$TOPLEVEL" != *"$EXPECTED_SUFFIX" ]]; then
        WORKTREE_DIR="${TOPLEVEL}/.worktrees/${SLUG}"
        if [ ! -d "$WORKTREE_DIR" ]; then
            # Option (a), allow-when-no-worktree (#1620): no owning worktree
            # exists, so the current checkout is the sole workspace for this
            # slug. There is nothing to contaminate — allow the commit.
            echo "" >&2
            echo "NOTE (#1288 guard, option a): branch session/${SLUG} committed from the main checkout." >&2
            echo "No worktree exists at ${WORKTREE_DIR} — the main checkout is the only workspace for this slug." >&2
            echo "Allowing the commit (nothing to contaminate). See #1620." >&2
            echo "" >&2
            # fall through — allow the commit to continue past Phase 0.5
        else
            echo ""
            echo "COMMIT BLOCKED: branch session/${SLUG} must be committed from inside .worktrees/${SLUG}/." >&2
            echo "Current working tree: ${TOPLEVEL}" >&2
            echo "Expected:             <repo_root>/.worktrees/${SLUG}/" >&2
            echo "" >&2
            echo "This is the #1288 guard. To proceed correctly:" >&2
            echo "  cd <repo_root>/.worktrees/${SLUG}" >&2
            echo "  git commit ..." >&2
            echo "" >&2
            echo "The owning worktree exists at:" >&2
            echo "  ${WORKTREE_DIR}" >&2
            echo ""
            exit 1
        fi
    fi
fi

# ── Phase 1: Auto-fix lint on staged Python files ──────────────────────
# Get list of staged Python files (Added, Copied, Modified)
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' | tr '\n' ' ')

if [ -n "$STAGED_PY_FILES" ]; then
    # Auto-format staged Python files
    "$PYTHON" -m ruff format --quiet $STAGED_PY_FILES 2>/dev/null || true

    # Auto-fix lint issues (fixable ones only)
    "$PYTHON" -m ruff check --fix --quiet $STAGED_PY_FILES 2>/dev/null || true

    # Re-stage the auto-fixed files
    git add $STAGED_PY_FILES

    # Now check if any unfixable issues remain
    if ! "$PYTHON" -m ruff check --quiet $STAGED_PY_FILES 2>/dev/null; then
        echo ""
        echo "COMMIT BLOCKED: Unfixable lint issues detected."
        echo "Fix the issues above and try again."
        echo ""
        exit 1
    fi
fi

# ── Phase 1.5: Lockfile sync check ────────────────────────────────────
# Verify `uv.lock` matches `pyproject.toml` so merges don't leave every
# machine with a dirty working tree after `uv sync`. `uv lock --locked`
# is read-only — it exits non-zero if regeneration would produce changes
# and never modifies files. Skip this phase entirely when neither file
# is staged (fast path for unrelated commits). Skip with a one-line
# warning if `uv` is not installed on this machine.
LOCKFILE_STAGED=$(git diff --cached --name-only | grep -E '^(pyproject\.toml|uv\.lock)$' || true)
if [ -n "$LOCKFILE_STAGED" ]; then
    if command -v uv >/dev/null 2>&1; then
        if ! uv lock --locked >/dev/null 2>&1; then
            echo ""
            echo "COMMIT BLOCKED: uv.lock is out of sync with pyproject.toml."
            echo "Fix: uv lock && git add uv.lock && git commit --amend --no-edit"
            echo "     (or include 'git add uv.lock' before committing again)"
            echo ""
            exit 1
        fi
    else
        echo "Warning: uv not found on PATH; skipping uv.lock sync check."
    fi
fi

# ── Phase 2: Secret scan ──────────────────────────────────────────────
SCRIPT="$REPO_ROOT/scripts/scan_secrets.py"

if [ ! -f "$SCRIPT" ]; then
    echo "Warning: scan_secrets.py not found, skipping secret scan"
    exit 0
fi

"$PYTHON" "$SCRIPT" --staged
if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: Secrets detected in staged files."
    echo "Remove the secrets and try again."
    echo ""
    exit 1
fi

{
  "name": "example-homepage",
  "url": "https://example.com",
  "steps": [
    {
      "action": "navigate",
      "url": "https://example.com"
    },
    {
      "action": "assert",
      "type": "title_equals",
      "value": "Example Domain"
    },
    {
      "action": "assert",
      "type": "text_visible",

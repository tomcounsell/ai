+
+        f = MagicMock()
+        f.importance = 5.0
+        f.confidence = 0.5
+        f._at_access_count = 0
+        f.content = "authentication module uses JWT"
+        f.file_paths = "auth/jwt.py"
+
+        score_with_topic = _composite_score(f, topics=["auth", "jwt"])
+        score_without_topic = _composite_score(f, topics=["database", "migration"])

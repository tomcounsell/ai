+
+        f_low = MagicMock()
+        f_low.importance = 1.0
+        f_low.confidence = 0.5
+        f_low._at_access_count = 0
+        f_low.content = "test"
+        f_low.file_paths = ""
+
+        assert _composite_score(f_high) > _composite_score(f_low)

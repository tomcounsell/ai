+
+        assert "method" in SUMMARIZER_SYSTEM_PROMPT.lower()
+        assert "function" in SUMMARIZER_SYSTEM_PROMPT.lower()
+        assert "class name" in SUMMARIZER_SYSTEM_PROMPT.lower()
+

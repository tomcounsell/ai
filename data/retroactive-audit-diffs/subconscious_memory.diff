+    Defaults.ACTED_CONFIDENCE_SIGNAL = MEMORY_ACTED_SIGNAL
+    Defaults.CONTRADICTED_CONFIDENCE_SIGNAL = MEMORY_CONTRADICTED_SIGNAL
+    Defaults.DISMISSED_CYCLE_WEAKEN_FACTOR = MEMORY_DISMISSED_WEAKEN

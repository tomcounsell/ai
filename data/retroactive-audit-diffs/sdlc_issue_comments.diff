+"""Unit tests for utils/issue_comments.py."""
+
+import json
+import logging
+import subprocess
+from unittest.mock import patch
+
+from utils.issue_comments import (
+    STAGE_COMMENT_MARKER,
+    fetch_stage_comments,
+    format_prior_context,

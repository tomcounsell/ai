+    defaults = {
+        "session_id": "test-session",
+        "delivery_action": None,
+        "delivery_text": None,
+        "delivery_emoji": None,
+        "is_sdlc": False,
+        "has_pm_messages": lambda: False,
+        "get_parent_chat_session": lambda: None,
+    }
+    defaults.update(kwargs)
+    return SimpleNamespace(**defaults)

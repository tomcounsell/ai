+{% if sessions %}
+<table class="data-table">
+    <thead>
+        <tr>
+            <th>Name</th>
+            <th>Type</th>
+            <th>Status</th>
+            <th>Project</th>
+            <th>SDLC Stages</th>
+            <th>Started</th>
+            <th>Duration</th>
+            <th></th>
+        </tr>
+    </thead>
+    <tbody>
+        {% for s in sessions %}
+        <tr class="session-row" hx-get="/sdlc/{{ s.job_id }}/_inline/" hx-target="#detail-{{ s.job_id }}" hx-swap="innerHTML" hx-trigger="click" style="cursor: pointer;">
+            <td>
+                <div class="card-title">{{ s.display_name }}</div>
+                {% if s.branch_name %}
+                <div class="text-muted mono" style="font-size: 11px;">{{ s.branch_name }}</div>
+                {% endif %}
+            </td>
+            <td>
+                {% if s.session_type %}
+                <span class="badge badge-{{ 'blue' if s.session_type == 'dev' else 'purple' }}">{{ s.session_type }}</span>
+                {% else %}
+                <span class="text-muted">-</span>
+                {% endif %}
+            </td>
+            <td>
+                {% if s.status %}
+                <span class="badge badge-{{ s.status }}">{{ s.status }}</span>
+                {% else %}
+                <span class="text-muted">-</span>
+                {% endif %}
+            </td>
+            <td class="mono">{{ s.project_key or '-' }}</td>
+            <td>
+                {% if s.stages %}
+                <div class="stage-indicator">
+                    {% for stage in s.stages %}
+                    {% if not loop.first %}<span class="stage-arrow">&#9654;</span>{% endif %}
+                    <span class="stage-dot {{ 'completed' if stage.is_done else ('in-progress' if stage.is_active else ('failed' if stage.is_failed else '')) }}">{{ stage.name }}</span>
+                    {% endfor %}
+                </div>
+                {% else %}
+                <span class="text-muted">-</span>
+                {% endif %}
+            </td>
+            <td class="mono">{{ s.started_at | format_timestamp }}</td>
+            <td class="mono">{{ s.duration | format_duration }}</td>
+            <td>
+                <div class="flex gap-2">
+                    {% if s.issue_url %}
+                    <a href="{{ s.issue_url }}" class="link" target="_blank" onclick="event.stopPropagation()">issue</a>
+                    {% endif %}
+                    {% if s.pr_url %}
+                    <a href="{{ s.pr_url }}" class="link" target="_blank" onclick="event.stopPropagation()">PR</a>
+                    {% endif %}
+                </div>
+            </td>
+        </tr>
+        <tr id="detail-{{ s.job_id }}" class="session-detail-row"></tr>
+        {% endfor %}
+    </tbody>
+</table>
+{% else %}
+<div class="empty-state">
+    <h3>No agent sessions</h3>
+    <p>Agent sessions will appear here when work is in progress.</p>
+</div>
+{% endif %}

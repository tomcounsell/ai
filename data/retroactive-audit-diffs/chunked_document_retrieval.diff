+                            orphan_count += 1
+                        except Exception:
+                            pass
+            except Exception:
+                pass
+
+        if orphan_count > 0:
+            logger.info(f"Cleaned up {orphan_count} orphan chunks")
+        return orphan_count
+
+    except Exception as e:
+        logger.warning(f"Orphan chunk cleanup failed (non-fatal): {e}")
+        return 0

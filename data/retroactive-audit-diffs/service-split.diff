+            echo "Launchd: INSTALLED (will auto-start)"
+        fi
+        return 1
+    fi
+}
+
+tail_worker_logs() {
+    echo "Tailing worker logs (Ctrl+C to stop)..."
+    tail -f "$LOG_DIR/worker.log" "$LOG_DIR/worker_error.log" 2>/dev/null
+}

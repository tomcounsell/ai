{
  "name": "selfie",
  "version": "1.0.0",
  "description": "Generate AI selfies of Valor Engels using OpenAI gpt-image-1 model",
  "type": "api",
  "status": "stable",

  "source": {
    "type": "internal",
    "repository": "https://github.com/tomcounsell/ai"
  },

  "capabilities": [
    "capture"
  ],

  "requires": {
    "env": ["OPENAI_API_KEY"],
    "python": ">=3.10",
    "packages": ["openai"]
  },

  "commands": {
    "verify": "python -c \"from tools.selfie import take_selfie; print('OK')\"",
    "test": "pytest tools/selfie/tests/ -v"
  },

  "config": {
    "default_size": "1024x1024",
    "scenes": ["office", "coffee", "outdoors", "evening", "working"]
  },

  "workflows": [
    {
      "name": "basic-selfie",
      "description": "Generate a selfie with a predefined scene",
      "steps": [
        "from tools.selfie import take_selfie",
        "result = take_selfie(scene='office')",
        "print(result['path'])"
      ]
    },
    {
      "name": "custom-selfie",
      "description": "Generate a selfie with custom context",
      "steps": [
        "from tools.selfie import take_selfie",
        "result = take_selfie(custom_context='at a tech conference')",
        "print(result['path'])"
      ]
    }
  ]
}
